CREATE DATABASE silver LOCATION 's3://meu-lakehouse/silver/';
CREATE DATABASE gold   LOCATION 's3://meu-lakehouse/gold/';
CREATE DATABASE mart   LOCATION 's3://meu-lakehouse/mart/';
