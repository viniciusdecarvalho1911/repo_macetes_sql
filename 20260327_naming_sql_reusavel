# Parte 1 — Query completa na íntegra

Abaixo está a versão consolidada e comentada.

```sql
-- =====================================================================================
-- QUERY: PAGAMENTOS CONSOLIDADOS COM META, GATE E COMISSIONAMENTO
-- =====================================================================================
-- OBJETIVO:
--   Consolidar pagamentos elegíveis a partir da carteira vigor, removendo contratos
--   presentes no colchão e no vijud do início do mês, unificando múltiplas fontes
--   de pagamento, aplicando regra de desconto, derivando caixa/regul, confrontando
--   com meta e chegando ao percentual de comissão por escritório.
--
-- ESTA QUERY FOI ESCRITA PARA SERVIR A DOIS PROPÓSITOS:
--   1) execução prática
--   2) material didático / modelo de arquitetura SQL
--
-- PADRÃO ADOTADO:
--   parametros -> base principal -> satélites -> enriquecimento -> regras
--   -> agregação -> output final
--
-- OBSERVAÇÃO:
--   Os nomes das views abaixo são exemplos estruturados.
--   Ajuste para os nomes reais do seu ambiente.
-- =====================================================================================

WITH

-- =====================================================================================
-- 1) PARÂMETROS
-- -------------------------------------------------------------------------------------
-- Centraliza tudo que muda com frequência:
-- - competência
-- - janela de pagamentos
-- - data de foto do vijud usada para exclusão
--
-- Benefícios:
-- - evita filtros espalhados
-- - facilita manutenção
-- - ajuda a transformar a query em "template" reaproveitável
-- =====================================================================================
parametros AS (
    SELECT
        202602 AS p_anomes,
        20260201 AS p_dt_inicio_mes,
        20260229 AS p_dt_fim_mes,
        20260201 AS p_dt_vijud_inicio_mes
),

-- =====================================================================================
-- 2) BASE PRINCIPAL: CARTEIRA VIGOR
-- -------------------------------------------------------------------------------------
-- Esta é a base principal da análise.
--
-- GRÃO:
--   1 linha por contrato + produto dentro da carteira vigor da competência
--
-- Repare que o filtro usa a coluna física de partição p_anomes.
-- Esse é o jeito certo de preservar pruning quando isso existe na base.
-- =====================================================================================
carteira_vigor AS (
    SELECT
        v.p_anomes,
        v.contrato,
        v.produto,
        v.cnpj_raiz,
        v.escritorio,
        v.fila,
        v.cluster_rv,
        v.atr_ctr,
        v.vl_saldo_gerencial
    FROM workspace_db.vw_base_carteira_vigor v
    CROSS JOIN parametros p
    WHERE v.p_anomes = p.p_anomes
),

-- =====================================================================================
-- 3) SATÉLITE: COLCHÃO DO MÊS
-- -------------------------------------------------------------------------------------
-- Esta CTE existe apenas para apoiar a exclusão de contratos que estejam no colchão.
--
-- DISTINCT é usado para evitar multiplicação desnecessária no join posterior.
-- =====================================================================================
colchao_mes AS (
    SELECT DISTINCT
        c.contrato,
        c.produto
    FROM workspace_db.vw_base_colchao c
    CROSS JOIN parametros p
    WHERE c.p_anomes = p.p_anomes
),

-- =====================================================================================
-- 4) SATÉLITE: VIJUD NO INÍCIO DO MÊS
-- -------------------------------------------------------------------------------------
-- Esta CTE captura quem estava no vijud na foto usada como corte.
--
-- Regra de negócio simulada:
--   contratos presentes aqui serão excluídos da carteira elegível.
-- =====================================================================================
vijud_inicio_mes AS (
    SELECT DISTINCT
        j.contrato,
        j.produto
    FROM workspace_db.vw_base_vijud_inicio_mes j
    CROSS JOIN parametros p
    WHERE j.p_dt_foto = p.p_dt_vijud_inicio_mes
),

-- =====================================================================================
-- 5) CARTEIRA ELEGÍVEL
-- -------------------------------------------------------------------------------------
-- Regra:
--   carteira_vigor
--   menos colchao_mes
--   menos vijud_inicio_mes
--
-- Técnica:
--   LEFT JOIN + IS NULL
--
-- É uma forma muito boa de representar exclusão de conjuntos de forma auditável.
-- =====================================================================================
carteira_elegivel AS (
    SELECT
        v.*
    FROM carteira_vigor v
    LEFT JOIN colchao_mes c
        ON v.contrato = c.contrato
       AND v.produto  = c.produto
    LEFT JOIN vijud_inicio_mes j
        ON v.contrato = j.contrato
       AND v.produto  = j.produto
    WHERE c.contrato IS NULL
      AND j.contrato IS NULL
),

-- =====================================================================================
-- 6) SATÉLITE: BOLETOS PAGOS VÁLIDOS
-- -------------------------------------------------------------------------------------
-- Esta é a primeira fonte de pagamento.
--
-- Regras:
--   - considera a janela do mês
--   - descarta boletos cancelados
--
-- Observação:
--   Se sua base tiver partição física específica (ex.: p_dt_ref), prefira filtrar por ela.
-- =====================================================================================
boletos_validos AS (
    SELECT
        b.contrato,
        b.produto,
        b.boleto,
        b.dt_pagamento,
        b.vl_pago,
        b.vl_desconto_boleto,
        'BOLETO' AS origem_pagamento
    FROM workspace_db.vw_base_boletos_pagos b
    CROSS JOIN parametros p
    WHERE b.dt_ref_yyyymmdd BETWEEN p.p_dt_inicio_mes AND p.p_dt_fim_mes
      AND COALESCE(b.flag_cancelado, 0) = 0
),

-- =====================================================================================
-- 7) SATÉLITE: DÉBITO EM CONTA
-- -------------------------------------------------------------------------------------
-- Segunda fonte de pagamento.
--
-- Aqui alguns campos não existem da mesma forma que em boletos.
-- Por isso padronizamos o layout para permitir UNION ALL depois.
-- =====================================================================================
debito_conta AS (
    SELECT
        d.contrato,
        d.produto,
        CAST(NULL AS VARCHAR) AS boleto,
        d.dt_pagamento,
        d.vl_pago,
        CAST(NULL AS DECIMAL(18,4)) AS vl_desconto_boleto,
        'DEBITO_CONTA' AS origem_pagamento
    FROM workspace_db.vw_base_debito_conta d
    CROSS JOIN parametros p
    WHERE d.dt_ref_yyyymmdd BETWEEN p.p_dt_inicio_mes AND p.p_dt_fim_mes
),

-- =====================================================================================
-- 8) SATÉLITE: FLUXO APARTADO / BACK OFFICE
-- -------------------------------------------------------------------------------------
-- Terceira fonte de pagamento.
--
-- De novo, padronizamos o layout para facilitar a consolidação posterior.
-- =====================================================================================
fluxo_apartado AS (
    SELECT
        f.contrato,
        f.produto,
        CAST(NULL AS VARCHAR) AS boleto,
        f.dt_pagamento,
        f.vl_pago,
        CAST(NULL AS DECIMAL(18,4)) AS vl_desconto_boleto,
        'BACKOFFICE' AS origem_pagamento
    FROM workspace_db.vw_base_fluxo_apartado f
    CROSS JOIN parametros p
    WHERE f.dt_ref_yyyymmdd BETWEEN p.p_dt_inicio_mes AND p.p_dt_fim_mes
),

-- =====================================================================================
-- 9) UNIÃO BRUTA DAS FONTES
-- -------------------------------------------------------------------------------------
-- Nesta etapa ainda não deduplicamos.
-- Apenas empilhamos as fontes.
--
-- UNION ALL é proposital:
--   - é mais barato
--   - não mascara duplicidade
--   - deixa a deduplicação explícita na próxima etapa
-- =====================================================================================
pagamentos_brutos AS (
    SELECT * FROM boletos_validos
    UNION ALL
    SELECT * FROM debito_conta
    UNION ALL
    SELECT * FROM fluxo_apartado
),

-- =====================================================================================
-- 10) DEDUPLICAÇÃO MULTIORIGEM
-- -------------------------------------------------------------------------------------
-- Esta é uma das etapas mais importantes da query.
--
-- Problema:
--   o mesmo pagamento pode aparecer em mais de uma origem
--
-- Estratégia:
--   usamos ROW_NUMBER para manter apenas 1 linha por evento de pagamento
--
-- CHAVE DE DEDUP DO EXEMPLO:
--   contrato + produto + dt_pagamento + vl_pago
--
-- IMPORTANTE:
--   isso é só um modelo didático
--   no seu ambiente real talvez você precise incluir boleto, id_evento, parcela etc.
--
-- ORDEM DE PREFERÊNCIA:
--   1) BOLETO
--   2) DEBITO_CONTA
--   3) BACKOFFICE
-- =====================================================================================
pagamentos_dedup AS (
    SELECT
        x.contrato,
        x.produto,
        x.boleto,
        x.dt_pagamento,
        x.vl_pago,
        x.vl_desconto_boleto,
        x.origem_pagamento
    FROM (
        SELECT
            p.*,
            ROW_NUMBER() OVER (
                PARTITION BY
                    p.contrato,
                    p.produto,
                    p.dt_pagamento,
                    p.vl_pago
                ORDER BY
                    CASE p.origem_pagamento
                        WHEN 'BOLETO' THEN 1
                        WHEN 'DEBITO_CONTA' THEN 2
                        WHEN 'BACKOFFICE' THEN 3
                        ELSE 99
                    END
            ) AS rn
        FROM pagamentos_brutos p
    ) x
    WHERE x.rn = 1
),

-- =====================================================================================
-- 11) PAGAMENTOS ELEGÍVEIS
-- -------------------------------------------------------------------------------------
-- Agora cruzamos:
--   carteira elegível
--   com
--   pagamentos deduplicados
--
-- Resultado:
--   ficamos apenas com pagamentos ligados à carteira válida da competência
-- =====================================================================================
pagamentos_elegiveis AS (
    SELECT
        c.p_anomes,
        c.contrato,
        c.produto,
        c.cnpj_raiz,
        c.escritorio,
        c.fila,
        c.cluster_rv,
        c.atr_ctr,
        c.vl_saldo_gerencial,
        p.boleto,
        p.dt_pagamento,
        p.vl_pago,
        p.vl_desconto_boleto,
        p.origem_pagamento
    FROM carteira_elegivel c
    INNER JOIN pagamentos_dedup p
        ON c.contrato = p.contrato
       AND c.produto  = p.produto
),

-- =====================================================================================
-- 12) PROPOSTA DE NEGÓCIO MAIS RECENTE
-- -------------------------------------------------------------------------------------
-- Se o desconto não vier do boleto, buscamos na proposta de negócio.
--
-- Regra simulada:
--   pega a proposta mais recente por contrato/produto/boleto
--
-- IMPORTANTE:
--   se o seu negócio exigir "proposta válida na data do pagamento",
--   essa lógica precisará evoluir para join temporal.
-- =====================================================================================
proposta_negocio_raw AS (
    SELECT
        pn.contrato,
        pn.produto,
        pn.boleto,
        pn.tp_acordo,
        pn.perc_desconto,
        pn.dt_referencia,
        ROW_NUMBER() OVER (
            PARTITION BY
                pn.contrato,
                pn.produto,
                COALESCE(pn.boleto, 'SEM_BOLETO')
            ORDER BY pn.dt_referencia DESC
        ) AS rn
    FROM workspace_db.vw_base_proposta_negocio pn
),

proposta_negocio AS (
    SELECT
        contrato,
        produto,
        boleto,
        tp_acordo,
        perc_desconto
    FROM proposta_negocio_raw
    WHERE rn = 1
),

-- =====================================================================================
-- 13) DESCONTO FINAL
-- -------------------------------------------------------------------------------------
-- Regra:
--   1) tenta o desconto vindo da base de boletos
--   2) se não houver, tenta a proposta de negócio
--   3) se nada existir, assume 0
--
-- Também traz o tipo de acordo, que será usado na regra de caixa vs regul.
-- =====================================================================================
pagamentos_com_desconto AS (
    SELECT
        p.p_anomes,
        p.contrato,
        p.produto,
        p.cnpj_raiz,
        p.escritorio,
        p.fila,
        p.cluster_rv,
        p.atr_ctr,
        p.vl_saldo_gerencial,
        p.boleto,
        p.dt_pagamento,
        p.vl_pago,
        p.origem_pagamento,
        pr.tp_acordo,
        COALESCE(
            p.vl_desconto_boleto,
            pr.perc_desconto,
            0
        ) AS perc_desconto_final
    FROM pagamentos_elegiveis p
    LEFT JOIN proposta_negocio pr
        ON p.contrato = pr.contrato
       AND p.produto  = pr.produto
       AND COALESCE(p.boleto, 'SEM_BOLETO') = COALESCE(pr.boleto, 'SEM_BOLETO')
),

-- =====================================================================================
-- 14) REGRAS FINANCEIRAS
-- -------------------------------------------------------------------------------------
-- Regra de negócio principal:
--
-- Se for À VISTA:
--   vl_caixa = vl_pago
--   vl_regul = 0
--
-- Caso contrário:
--   vl_caixa = 0
--   vl_regul = saldo_gerencial - (saldo_gerencial * desconto)
--
-- IMPORTANTE:
--   esta fórmula é um exemplo baseado no seu enunciado.
--   confirme com o negócio se desconto está em formato decimal (ex.: 0.25)
--   e se regul deve mesmo sair do saldo gerencial por essa fórmula.
-- =====================================================================================
regras_financeiras AS (
    SELECT
        p.*,

        CASE
            WHEN UPPER(COALESCE(p.tp_acordo, '')) IN ('AVISTA', 'A VISTA', 'A_VISTA')
                THEN p.vl_pago
            ELSE 0
        END AS vl_caixa,

        CASE
            WHEN UPPER(COALESCE(p.tp_acordo, '')) IN ('AVISTA', 'A VISTA', 'A_VISTA')
                THEN 0
            ELSE p.vl_saldo_gerencial
                 - (p.vl_saldo_gerencial * p.perc_desconto_final)
        END AS vl_regul
    FROM pagamentos_com_desconto p
),

-- =====================================================================================
-- 15) AGREGAÇÃO POR ESCRITÓRIO
-- -------------------------------------------------------------------------------------
-- A partir daqui entramos no mundo analítico.
--
-- GRÃO:
--   competência + escritório
-- =====================================================================================
resultado_escritorio AS (
    SELECT
        p_anomes,
        escritorio,
        COUNT(DISTINCT contrato) AS qtd_contratos_pagantes,
        SUM(vl_caixa) AS vl_caixa,
        SUM(vl_regul) AS vl_regul
    FROM regras_financeiras
    GROUP BY 1,2
),

-- =====================================================================================
-- 16) META DO ESCRITÓRIO
-- -------------------------------------------------------------------------------------
-- A meta precisa estar no mesmo grão da apuração final.
-- =====================================================================================
meta_escritorio AS (
    SELECT
        m.p_anomes,
        m.escritorio,
        m.vl_meta_regul
    FROM workspace_db.vw_base_meta_escritorio m
    CROSS JOIN parametros p
    WHERE m.p_anomes = p.p_anomes
),

-- =====================================================================================
-- 17) RESULTADO x META
-- -------------------------------------------------------------------------------------
-- Aqui calculamos o percentual de atingimento.
--
-- Proteção:
--   evita divisão por zero
-- =====================================================================================
resultado_meta AS (
    SELECT
        r.p_anomes,
        r.escritorio,
        r.qtd_contratos_pagantes,
        r.vl_caixa,
        r.vl_regul,
        m.vl_meta_regul,
        CASE
            WHEN COALESCE(m.vl_meta_regul, 0) > 0
                THEN r.vl_regul / m.vl_meta_regul
            ELSE NULL
        END AS perc_atingimento
    FROM resultado_escritorio r
    LEFT JOIN meta_escritorio m
        ON r.p_anomes   = m.p_anomes
       AND r.escritorio = m.escritorio
),

-- =====================================================================================
-- 18) GATE / COMISSIONAMENTO
-- -------------------------------------------------------------------------------------
-- Idealmente isso vem de uma tabela de regra (lookup/de-para), e não de CASE gigante.
--
-- Exemplo de colunas esperadas:
--   escritorio
--   faixa_ini
--   faixa_fim
--   gate
--   perc_comissao
-- =====================================================================================
gate_comissao AS (
    SELECT
        g.escritorio,
        g.faixa_ini,
        g.faixa_fim,
        g.gate,
        g.perc_comissao
    FROM workspace_db.vw_base_gate_comissionamento g
),

-- =====================================================================================
-- 19) LOOKUP FINAL DO GATE
-- -------------------------------------------------------------------------------------
-- Atenção:
--   as faixas de gate não podem se sobrepor.
--   Se houver sobreposição, um escritório pode casar com mais de uma linha.
-- =====================================================================================
resultado_final AS (
    SELECT
        r.p_anomes,
        r.escritorio,
        r.qtd_contratos_pagantes,
        r.vl_caixa,
        r.vl_regul,
        r.vl_meta_regul,
        r.perc_atingimento,
        g.gate,
        g.perc_comissao,
        r.vl_regul * g.perc_comissao AS vl_comissao
    FROM resultado_meta r
    LEFT JOIN gate_comissao g
        ON r.escritorio = g.escritorio
       AND r.perc_atingimento >= g.faixa_ini
       AND r.perc_atingimento <  g.faixa_fim
)

-- =====================================================================================
-- 20) OUTPUT FINAL
-- -------------------------------------------------------------------------------------
-- O output final deve ficar simples.
-- Se o select final estiver caótico, normalmente a modelagem anterior ainda está ruim.
-- =====================================================================================
SELECT
    p_anomes,
    escritorio,
    qtd_contratos_pagantes,
    vl_caixa,
    vl_regul,
    vl_meta_regul,
    perc_atingimento,
    gate,
    perc_comissao,
    vl_comissao
FROM resultado_final
ORDER BY
    p_anomes,
    escritorio;
```

