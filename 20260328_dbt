## 3.1 `int_carteira_elegivel_pagamento.sql`

```sql
with carteira_vigor as (
    select *
    from {{ ref('stg_carteira_vigor') }}
    where p_anomes = 202602
),

colchao_mes as (
    select distinct contrato, produto
    from {{ ref('stg_colchao') }}
    where p_anomes = 202602
),

vijud_inicio_mes as (
    select distinct contrato, produto
    from {{ ref('stg_vijud_inicio_mes') }}
    where p_dt_foto = 20260201
)

select
    v.*
from carteira_vigor v
left join colchao_mes c
  on v.contrato = c.contrato
 and v.produto  = c.produto
left join vijud_inicio_mes j
  on v.contrato = j.contrato
 and v.produto  = j.produto
where c.contrato is null
  and j.contrato is null
```

