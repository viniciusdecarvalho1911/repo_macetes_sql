## 3.3 `int_pagamentos_com_desconto.sql`

```sql
with pagamentos as (
    select *
    from {{ ref('int_pagamentos_multiorigem') }}
),

proposta as (
    select *
    from (
        select
            contrato,
            produto,
            boleto,
            tp_acordo,
            perc_desconto,
            row_number() over (
                partition by contrato, produto, coalesce(boleto, 'SEM_BOLETO')
                order by dt_referencia desc
            ) as rn
        from {{ ref('stg_proposta_negocio') }}
    ) x
    where rn = 1
)

select
    p.*,
    pr.tp_acordo,
    coalesce(
        p.vl_desconto_boleto,
        pr.perc_desconto,
        0
    ) as perc_desconto_final
from pagamentos p
left join proposta pr
  on p.contrato = pr.contrato
 and p.produto  = pr.produto
 and coalesce(p.boleto, 'SEM_BOLETO') = coalesce(pr.boleto, 'SEM_BOLETO')
```

