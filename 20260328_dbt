## 3.4 `int_pagamento_consolidado.sql`

```sql
with carteira as (
    select *
    from {{ ref('int_carteira_elegivel_pagamento') }}
),

pagamentos as (
    select *
    from {{ ref('int_pagamentos_com_desconto') }}
),

joined as (
    select
        c.p_anomes,
        c.contrato,
        c.produto,
        c.cnpj_raiz,
        c.escritorio,
        c.fila,
        c.cluster_rv,
        c.vl_saldo_gerencial,
        p.boleto,
        p.dt_pagamento,
        p.vl_pago,
        p.origem_pagamento,
        p.tp_acordo,
        p.perc_desconto_final
    from carteira c
    inner join pagamentos p
      on c.contrato = p.contrato
     and c.produto  = p.produto
)

select
    *,
    case
        when upper(coalesce(tp_acordo, '')) in ('AVISTA', 'A VISTA', 'A_VISTA')
            then vl_pago
        else 0
    end as vl_caixa,
    case
        when upper(coalesce(tp_acordo, '')) in ('AVISTA', 'A VISTA', 'A_VISTA')
            then 0
        else vl_saldo_gerencial - (vl_saldo_gerencial * perc_desconto_final)
    end as vl_regul
from joined
```

