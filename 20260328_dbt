## 3.2 `int_pagamentos_multiorigem.sql`

```sql
with boletos_validos as (
    select
        contrato,
        produto,
        boleto,
        dt_ref_yyyymmdd as dt_pagamento,
        vl_pago,
        vl_desconto_boleto,
        'BOLETO' as origem_pagamento
    from {{ ref('stg_boletos_pagos') }}
    where dt_ref_yyyymmdd between 20260201 and 20260229
      and flag_cancelado = 0
),

debito_conta as (
    select
        contrato,
        produto,
        cast(null as varchar) as boleto,
        dt_pagamento,
        vl_pago,
        cast(null as decimal(18,4)) as vl_desconto_boleto,
        'DEBITO_CONTA' as origem_pagamento
    from {{ ref('stg_debito_conta') }}
    where dt_ref_yyyymmdd between 20260201 and 20260229
),

fluxo_apartado as (
    select
        contrato,
        produto,
        cast(null as varchar) as boleto,
        dt_pagamento,
        vl_pago,
        cast(null as decimal(18,4)) as vl_desconto_boleto,
        'BACKOFFICE' as origem_pagamento
    from {{ ref('stg_fluxo_apartado') }}
    where dt_ref_yyyymmdd between 20260201 and 20260229
),

pagamentos_brutos as (
    select * from boletos_validos
    union all
    select * from debito_conta
    union all
    select * from fluxo_apartado
),

pagamentos_dedup as (
    select *
    from (
        select
            p.*,
            row_number() over (
                partition by contrato, produto, dt_pagamento, vl_pago
                order by
                    case origem_pagamento
                        when 'BOLETO' then 1
                        when 'DEBITO_CONTA' then 2
                        when 'BACKOFFICE' then 3
                        else 99
                    end
            ) as rn
        from pagamentos_brutos p
    ) x
    where rn = 1
)

select * from pagamentos_dedup
```

