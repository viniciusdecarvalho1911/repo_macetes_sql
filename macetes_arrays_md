# 24. Exemplo de tabela final completa

```sql
CREATE TABLE analytics.contrato_hist_analitico
WITH (
    format = 'PARQUET',
    external_location = 's3://seu-bucket/analytics/contrato_hist_analitico/'
) AS
WITH base AS (
    SELECT
        contrato,
        anomesdia,
        substr(cast(anomesdia AS varchar), 1, 6) AS mesref,
        cast(date_parse(cast(anomesdia AS varchar), '%Y%m%d') AS date) AS dt_ref,
        cast(dt_atraso AS integer) AS dt_atraso,
        cast(status AS varchar) AS status,
        cast(escritorio AS varchar) AS escritorio,
        cast(evento AS varchar) AS evento
    FROM origem
),
foto_mes AS (
    SELECT
        contrato,
        mesref,
        max_by(status, anomesdia) AS status_mes,
        max_by(escritorio, anomesdia) AS escritorio_mes
    FROM base
    GROUP BY 1, 2
),
atraso_mes AS (
    SELECT
        contrato,
        mesref,
        min(CASE WHEN coalesce(dt_atraso, 0) > 0 THEN dt_ref END) AS dt_primeiro_atraso,
        max(CASE WHEN coalesce(dt_atraso, 0) > 0 THEN dt_ref END) AS dt_ultimo_atraso,
        max(CASE WHEN coalesce(dt_atraso, 0) > 0 THEN dt_atraso END) AS atraso_max,
        count_if(coalesce(dt_atraso, 0) > 0) AS dias_em_atraso,
        max_by(
            CASE
                WHEN coalesce(status, '') IN ('ACORDO', 'RENEGOCIADO') THEN 'RENEGOCIADO'
                WHEN coalesce(dt_atraso, 0) = 0 THEN 'COLOCADO_EM_DIA'
                WHEN coalesce(dt_atraso, 0) > 0 THEN 'EM_ABERTO'
                ELSE NULL
            END,
            anomesdia
        ) AS resolucao_mes
    FROM base
    GROUP BY 1, 2
),
hist_atraso AS (
    SELECT
        contrato,
        array_agg(
            CAST(
                ROW(
                    mesref,
                    dt_primeiro_atraso,
                    dt_ultimo_atraso,
                    atraso_max,
                    dias_em_atraso,
                    resolucao_mes
                )
                AS ROW(
                    mesref VARCHAR,
                    dt_primeiro_atraso DATE,
                    dt_ultimo_atraso DATE,
                    atraso_max INTEGER,
                    dias_em_atraso BIGINT,
                    resolucao_mes VARCHAR
                )
            )
            ORDER BY mesref
        ) AS hist_atraso
    FROM atraso_mes
    GROUP BY contrato
),
hist_status AS (
    SELECT
        contrato,
        array_agg(
            CAST(
                ROW(mesref, status_mes)
                AS ROW(mesref VARCHAR, status VARCHAR)
            )
            ORDER BY mesref
        ) AS hist_status
    FROM foto_mes
    GROUP BY contrato
),
hist_escritorio AS (
    SELECT
        contrato,
        array_agg(
            CAST(
                ROW(mesref, escritorio_mes)
                AS ROW(mesref VARCHAR, escritorio VARCHAR)
            )
            ORDER BY mesref
        ) AS hist_escritorio
    FROM foto_mes
    GROUP BY contrato
),
hist_eventos AS (
    SELECT
        contrato,
        array_agg(
            CAST(
                ROW(dt_ref, evento)
                AS ROW(dt_evento DATE, evento VARCHAR)
            )
            ORDER BY dt_ref
        ) FILTER (WHERE evento IS NOT NULL) AS hist_eventos
    FROM base
    GROUP BY contrato
)
SELECT
    c.contrato,
    a.hist_atraso,
    s.hist_status,
    e.hist_escritorio,
    v.hist_eventos
FROM (SELECT DISTINCT contrato FROM base) c
LEFT JOIN hist_atraso a ON c.contrato = a.contrato
LEFT JOIN hist_status s ON c.contrato = s.contrato
LEFT JOIN hist_escritorio e ON c.contrato = e.contrato
LEFT JOIN hist_eventos v ON c.contrato = v.contrato;
```

