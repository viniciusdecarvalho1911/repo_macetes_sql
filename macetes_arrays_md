# 15. Como montar histórico mensal de atraso

Agora algo mais próximo do seu caso.

## Objetivo

Para cada contrato, guardar por mês:

* `mesref`
* data do primeiro atraso
* data do último atraso
* atraso máximo
* quantidade de dias com atraso
* resolução do mês

## Base diária

Suponha:

```text
contrato | anomesdia | dt_atraso | status
---------+-----------+-----------+---------
123      | 20260101  | 0         | OK
123      | 20260110  | 5         | ATRASO
123      | 20260120  | 16        | ATRASO
123      | 20260125  | 0         | OK
123      | 20260210  | 10        | ATRASO
123      | 20260220  | 45        | RENEGOCIADO
```

## Passo 1 — normalizar datas e mesref

```sql
WITH base AS (
    SELECT
        contrato,
        substr(cast(anomesdia AS varchar), 1, 6) AS mesref,
        cast(date_parse(cast(anomesdia AS varchar), '%Y%m%d') AS date) AS dt_ref,
        cast(dt_atraso AS integer) AS dt_atraso,
        cast(status AS varchar) AS status
    FROM origem
)
SELECT *
FROM base;
```

## Passo 2 — resumir por contrato e mês

```sql
WITH base AS (
    SELECT
        contrato,
        substr(cast(anomesdia AS varchar), 1, 6) AS mesref,
        cast(date_parse(cast(anomesdia AS varchar), '%Y%m%d') AS date) AS dt_ref,
        cast(dt_atraso AS integer) AS dt_atraso,
        cast(status AS varchar) AS status
    FROM origem
),
resumo_mes AS (
    SELECT
        contrato,
        mesref,
        min(CASE WHEN coalesce(dt_atraso, 0) > 0 THEN dt_ref END) AS dt_primeiro_atraso,
        max(CASE WHEN coalesce(dt_atraso, 0) > 0 THEN dt_ref END) AS dt_ultimo_atraso,
        max(CASE WHEN coalesce(dt_atraso, 0) > 0 THEN dt_atraso END) AS atraso_max,
        count_if(coalesce(dt_atraso, 0) > 0) AS dias_em_atraso,
        max_by(
            CASE
                WHEN coalesce(status, '') IN ('ACORDO', 'RENEGOCIADO') THEN 'RENEGOCIADO'
                WHEN coalesce(dt_atraso, 0) = 0 THEN 'COLOCADO_EM_DIA'
                WHEN coalesce(dt_atraso, 0) > 0 THEN 'EM_ABERTO'
                ELSE NULL
            END,
            dt_ref
        ) AS resolucao_mes
    FROM base
    GROUP BY 1, 2
)
SELECT *
FROM resumo_mes;
```

## Passo 3 — montar `hist_atraso`

```sql
WITH base AS (
    SELECT
        contrato,
        substr(cast(anomesdia AS varchar), 1, 6) AS mesref,
        cast(date_parse(cast(anomesdia AS varchar), '%Y%m%d') AS date) AS dt_ref,
        cast(dt_atraso AS integer) AS dt_atraso,
        cast(status AS varchar) AS status
    FROM origem
),
resumo_mes AS (
    SELECT
        contrato,
        mesref,
        min(CASE WHEN coalesce(dt_atraso, 0) > 0 THEN dt_ref END) AS dt_primeiro_atraso,
        max(CASE WHEN coalesce(dt_atraso, 0) > 0 THEN dt_ref END) AS dt_ultimo_atraso,
        max(CASE WHEN coalesce(dt_atraso, 0) > 0 THEN dt_atraso END) AS atraso_max,
        count_if(coalesce(dt_atraso, 0) > 0) AS dias_em_atraso,
        max_by(
            CASE
                WHEN coalesce(status, '') IN ('ACORDO', 'RENEGOCIADO') THEN 'RENEGOCIADO'
                WHEN coalesce(dt_atraso, 0) = 0 THEN 'COLOCADO_EM_DIA'
                WHEN coalesce(dt_atraso, 0) > 0 THEN 'EM_ABERTO'
                ELSE NULL
            END,
            dt_ref
        ) AS resolucao_mes
    FROM base
    GROUP BY 1, 2
)
SELECT
    contrato,
    array_agg(
        CAST(
            ROW(
                mesref,
                dt_primeiro_atraso,
                dt_ultimo_atraso,
                atraso_max,
                dias_em_atraso,
                resolucao_mes
            )
            AS ROW(
                mesref VARCHAR,
                dt_primeiro_atraso DATE,
                dt_ultimo_atraso DATE,
                atraso_max INTEGER,
                dias_em_atraso BIGINT,
                resolucao_mes VARCHAR
            )
        )
        ORDER BY mesref
    ) AS hist_atraso
FROM resumo_mes
GROUP BY contrato;
```

