import re
import json
from collections import Counter, defaultdict
from textwrap import dedent


class AthenaExplainInterpreterV4:
    """
    Interpretador heurístico de EXPLAIN / EXPLAIN ANALYZE para Athena/Trino.

    Objetivo:
    - Ler planos gigantes
    - Resumir hotspots
    - Sugerir melhorias
    - Tentar mapear blocos suspeitos do SQL original
    """

    def __init__(self, explain_text: str, sql_text: str | None = None):
        self.text = explain_text or ""
        self.sql = sql_text or ""
        self.lines = self.text.splitlines()

    # =========================
    # Helpers básicos
    # =========================
    def _find_all(self, pattern, flags=re.IGNORECASE):
        return re.findall(pattern, self.text, flags)

    def _count(self, pattern, flags=re.IGNORECASE):
        return len(re.findall(pattern, self.text, flags))

    def _contains(self, pattern, flags=re.IGNORECASE):
        return bool(re.search(pattern, self.text, flags))

    # =========================
    # Estrutura geral do plano
    # =========================
    def detect_fragments(self):
        patterns = [
            r"\bFragment\s+\d+\b",
            r"\bFragment\s+\[\d+\]\b",
            r"\bSubPlan\b"
        ]
        found = []
        for p in patterns:
            found.extend(re.findall(p, self.text, re.IGNORECASE))
        return len(found)

    def count_operators(self):
        operators = {
            "TableScan": r"\bTableScan\b",
            "ScanFilterProject": r"\bScanFilterProject\b",
            "Filter": r"\bFilter\b",
            "Project": r"\bProject\b",
            "Join": r"\bJoin\b",
            "CrossJoin": r"\bCrossJoin\b",
            "SemiJoin": r"\bSemiJoin\b",
            "Aggregation": r"\bAggregation\b",
            "MarkDistinct": r"\bMarkDistinct\b",
            "Window": r"\bWindow\b",
            "RowNumber": r"\bRowNumber\b",
            "TopN": r"\bTopN\b",
            "Sort": r"\bSort\b",
            "Exchange": r"\bExchange\b",
            "RemoteSource": r"\bRemoteSource\b",
            "Unnest": r"\bUnnest\b",
            "Limit": r"\bLimit\b",
            "Values": r"\bValues\b"
        }

        counts = {}
        for name, pattern in operators.items():
            counts[name] = self._count(pattern)
        return counts

    # =========================
    # Tabelas / scans
    # =========================
    def detect_tables(self):
        patterns = [
            r"table\s*=\s*([\w\.\-\"`]+)",
            r"TableScan\[[^\]]*?([\w]+\.[\w]+)[^\]]*\]",
            r"\bfrom\s+([\w]+\.[\w]+)\b"
        ]

        tables = []
        for p in patterns:
            tables.extend(self._find_all(p))

        normalized = []
        for t in tables:
            t = t.strip().strip('"').strip("`")
            if "." in t:
                normalized.append(t.lower())

        return Counter(normalized)

    def detect_repeated_scans(self):
        tables = self.detect_tables()
        repeated = {k: v for k, v in tables.items() if v > 1}
        return dict(sorted(repeated.items(), key=lambda x: x[1], reverse=True))

    # =========================
    # Joins
    # =========================
    def detect_join_types(self):
        patterns = [
            r"\b(INNER|LEFT|RIGHT|FULL|CROSS)\s+JOIN\b",
            r"\bJoin\[(INNER|LEFT|RIGHT|FULL|CROSS)",
        ]
        found = []
        for p in patterns:
            found.extend(self._find_all(p))
        found = [x.upper() for x in found]
        return Counter(found)

    def detect_distribution_types(self):
        dist = {
            "PARTITIONED": self._count(r"\bPARTITIONED\b"),
            "REPLICATED": self._count(r"\bREPLICATED\b"),
            "HASH": self._count(r"\bHASH\b"),
            "SINGLE": self._count(r"\bSINGLE\b"),
            "BROADCAST_HINT": self._count(r"\bBROADCAST\b"),
        }
        return dist

    def detect_cross_join(self):
        return self._contains(r"\bCrossJoin\b|\bCROSS\s+JOIN\b")

    # =========================
    # Filtros / pruning
    # =========================
    def detect_filters(self):
        return {
            "Filter": self._count(r"\bFilter\b"),
            "ScanFilterProject": self._count(r"\bScanFilterProject\b"),
            "predicate_mentions": self._count(r"\bpredicate\b|\bfilterPredicate\b|\blayout\b|\bconstraint\b")
        }

    def detect_partition_signals(self):
        signals = {
            "partition_mentions": self._count(r"\bpartition\b"),
            "partitions_scanned_mentions": self._count(r"\bpartitions?\b"),
            "dynamic_filter_mentions": self._count(r"\bdynamic\s*filter\b"),
            "where_mentions_in_sql": self._count(r"\bwhere\b", flags=re.IGNORECASE) if self.sql else 0
        }
        return signals

    def detect_possible_missing_pruning(self):
        tables = self.detect_tables()
        filters = self.detect_filters()
        part = self.detect_partition_signals()

        reasons = []

        if sum(tables.values()) >= 3 and filters["Filter"] + filters["ScanFilterProject"] == 0:
            reasons.append("Há vários scans e quase nenhum operador explícito de filtro no plano.")

        if part["partition_mentions"] == 0 and self.sql:
            if re.search(r"\banomes\b|\banomesdia\b|\bdt_\w+\b|\bdata\b|\bmesref\b", self.sql, re.IGNORECASE):
                reasons.append("O SQL aparenta usar colunas temporais, mas o plano quase não menciona partições/pruning.")

        if tables and len(tables) >= 2 and filters["predicate_mentions"] == 0:
            reasons.append("Há leituras de múltiplas tabelas sem sinais fortes de predicates/layout constraints no plano.")

        return reasons

    # =========================
    # Exchange / shuffle / single node
    # =========================
    def detect_exchange_types(self):
        patterns = [
            r"\bExchange\s+(\w+)",
            r"\bExchange\[(\w+)\]",
        ]
        found = []
        for p in patterns:
            found.extend(self._find_all(p))
        found = [x.upper() for x in found]
        return Counter(found)

    def detect_single_node_risk(self):
        reasons = []
        single_count = self._count(r"\bSINGLE\b")
        sort_count = self._count(r"\bSort\b")
        global_agg_count = self._count(r"\bFinalAggregation\b|\bAggregation\b")

        if single_count >= 2:
            reasons.append(f"O plano menciona SINGLE {single_count} vezes, sugerindo gargalos concentrados em um nó.")
        if single_count >= 1 and sort_count >= 1:
            reasons.append("Há combinação de SINGLE com SORT, o que pode concentrar ordenação em um único nó.")
        if single_count >= 1 and global_agg_count >= 2:
            reasons.append("Há SINGLE junto de agregações, o que pode indicar estágio final serializado.")

        return reasons

    def detect_shuffle_risk(self):
        exchanges = self.detect_exchange_types()
        dist = self.detect_distribution_types()
        reasons = []

        total_exchange = sum(exchanges.values())
        if total_exchange >= 5:
            reasons.append(f"Há {total_exchange} exchanges no plano, sugerindo shuffle relevante entre nós.")

        if dist["HASH"] >= 3:
            reasons.append("Há muitos HASH exchanges, normalmente associados a reparticionamento por chave.")

        if dist["PARTITIONED"] >= 2 and dist["REPLICATED"] == 0:
            reasons.append("Predominam joins/steps PARTITIONED; isso costuma aumentar custo de redistribuição.")

        return reasons

    # =========================
    # Window / sort / unnest
    # =========================
    def detect_advanced_operator_risks(self):
        reasons = []

        window_count = self._count(r"\bWindow\b")
        sort_count = self._count(r"\bSort\b")
        topn_count = self._count(r"\bTopN\b")
        unnest_count = self._count(r"\bUnnest\b")
        markdistinct_count = self._count(r"\bMarkDistinct\b")

        if window_count >= 2:
            reasons.append(f"Há {window_count} operadores Window; funções analíticas em cascata podem ser caras.")
        if sort_count >= 2:
            reasons.append(f"Há {sort_count} operadores Sort; ordenações múltiplas podem elevar memória e spill.")
        if topn_count >= 2:
            reasons.append(f"Há {topn_count} operadores TopN; pode haver ordenação parcial repetida.")
        if unnest_count >= 1:
            reasons.append("Há UNNEST no plano; isso pode multiplicar linhas e aumentar cardinalidade.")
        if markdistinct_count >= 1:
            reasons.append("Há MarkDistinct; DISTINCTs complexos podem gerar custo extra de memória.")

        return reasons

    # =========================
    # Spill / memória / skew
    # =========================
    def detect_runtime_signals(self):
        """
        Funciona melhor quando o usuário cola EXPLAIN ANALYZE ou detalhes de execução.
        """
        signals = {
            "spill_mentions": self._count(r"\bspill\b"),
            "memory_mentions": self._count(r"\bmemory\b"),
            "skew_mentions": self._count(r"\bskew\b"),
            "blocked_mentions": self._count(r"\bblocked\b"),
            "cpu_mentions": self._count(r"\bcpu\b"),
            "scheduled_mentions": self._count(r"\bscheduled\b"),
            "input_rows_mentions": self._count(r"\binput\b.*\brows\b|\binputRows\b"),
            "output_rows_mentions": self._count(r"\boutput\b.*\brows\b|\boutputRows\b")
        }
        return signals

    def detect_memory_skew_risk(self):
        runtime = self.detect_runtime_signals()
        reasons = []

        if runtime["spill_mentions"] >= 1:
            reasons.append("Há menção a spill; a query pode estar excedendo memória em operadores intermediários.")
        if runtime["memory_mentions"] >= 2:
            reasons.append("Há várias menções a memory; vale investigar pressão de memória nos stages.")
        if runtime["skew_mentions"] >= 1:
            reasons.append("Há sinal textual de skew; pode existir distribuição desigual de chaves.")
        if runtime["blocked_mentions"] >= 2:
            reasons.append("Há menções a blocked time; pode haver espera em exchange, I/O ou contenção.")
        return reasons

    # =========================
    # SQL original / CTEs
    # =========================
    def detect_ctes_from_sql(self):
        if not self.sql.strip():
            return []

        patterns = [
            r"with\s+(.*?)\s+select",
        ]

        ctes = re.findall(r"(\w+)\s+as\s*\(", self.sql, re.IGNORECASE)
        return [c.lower() for c in ctes]

    def map_suspicious_ctes(self):
        """
        Heurística fraca, mas útil:
        - tenta identificar CTEs com nomes sugestivos
        - tenta cruzar quantidade de joins/windows/aggregations no SQL
        """
        if not self.sql.strip():
            return []

        ctes = self.detect_ctes_from_sql()
        suspicious = []

        for cte in ctes:
            pattern = rf"{re.escape(cte)}\s+as\s*\((.*?)\)\s*(,|\bselect\b)"
            match = re.search(pattern, self.sql, re.IGNORECASE | re.DOTALL)

            if not match:
                continue

            body = match.group(1)

            score = 0
            reasons = []

            join_count = len(re.findall(r"\bjoin\b", body, re.IGNORECASE))
            window_count = len(re.findall(r"\bover\s*\(", body, re.IGNORECASE))
            group_count = len(re.findall(r"\bgroup\s+by\b", body, re.IGNORECASE))
            distinct_count = len(re.findall(r"\bdistinct\b", body, re.IGNORECASE))
            union_count = len(re.findall(r"\bunion\b", body, re.IGNORECASE))
            unnest_count = len(re.findall(r"\bunnest\b", body, re.IGNORECASE))

            score += join_count * 2
            score += window_count * 2
            score += group_count * 2
            score += distinct_count * 1
            score += union_count * 2
            score += unnest_count * 2

            if join_count >= 2:
                reasons.append(f"{join_count} joins")
            if window_count >= 1:
                reasons.append(f"{window_count} windows")
            if group_count >= 1:
                reasons.append(f"{group_count} agrupamentos")
            if distinct_count >= 1:
                reasons.append(f"{distinct_count} distincts")
            if union_count >= 1:
                reasons.append(f"{union_count} unions")
            if unnest_count >= 1:
                reasons.append(f"{unnest_count} unnest")

            if score >= 4:
                suspicious.append({
                    "cte": cte,
                    "score_heurstico": score,
                    "motivos": reasons
                })

        suspicious = sorted(suspicious, key=lambda x: x["score_heurstico"], reverse=True)
        return suspicious

    # =========================
    # Score de risco
    # =========================
    def estimate_cost_risk(self):
        ops = self.count_operators()
        dist = self.detect_distribution_types()

        score = 0
        score += ops["Join"] * 2
        score += ops["Exchange"] * 3
        score += ops["Window"] * 2
        score += ops["Sort"] * 2
        score += ops["Aggregation"] * 1
        score += ops["Unnest"] * 3
        score += ops["CrossJoin"] * 8
        score += dist["SINGLE"] * 3
        score += dist["PARTITIONED"] * 2

        if score < 12:
            return {"nivel": "Baixo", "score": score}
        elif score < 25:
            return {"nivel": "Médio", "score": score}
        elif score < 40:
            return {"nivel": "Alto", "score": score}
        return {"nivel": "Muito Alto", "score": score}

    # =========================
    # Diagnóstico consolidado
    # =========================
    def build_findings(self):
        findings = []

        if self.detect_cross_join():
            findings.append({
                "categoria": "Join",
                "severidade": "Crítica",
                "titulo": "Cross join detectado",
                "evidencia": "O plano contém CROSS JOIN / CrossJoin.",
                "impacto": "Pode multiplicar linhas de forma explosiva.",
                "acao": "Validar condição de join ausente ou reestruturar lógica."
            })

        for reason in self.detect_single_node_risk():
            findings.append({
                "categoria": "Distribuição",
                "severidade": "Alta",
                "titulo": "Possível gargalo single-node",
                "evidencia": reason,
                "impacto": "Parte do processamento pode ficar concentrada em um único nó.",
                "acao": "Reduzir ordenações finais, agregações globais e reavaliar desenho do SQL."
            })

        for reason in self.detect_shuffle_risk():
            findings.append({
                "categoria": "Shuffle",
                "severidade": "Alta",
                "titulo": "Alto volume potencial de redistribuição",
                "evidencia": reason,
                "impacto": "Pode elevar tempo, custo e uso de rede entre nós.",
                "acao": "Filtrar antes de join, pré-agregar, materializar etapas e revisar chaves."
            })

        for reason in self.detect_advanced_operator_risks():
            findings.append({
                "categoria": "Operadores caros",
                "severidade": "Média",
                "titulo": "Operadores analíticos custosos",
                "evidencia": reason,
                "impacto": "Pode aumentar CPU, memória e spill.",
                "acao": "Reduzir janelas desnecessárias, ordenar menos e materializar blocos complexos."
            })

        for reason in self.detect_memory_skew_risk():
            findings.append({
                "categoria": "Runtime",
                "severidade": "Alta",
                "titulo": "Sinais de spill / memória / skew",
                "evidencia": reason,
                "impacto": "Pode causar degradação forte de performance.",
                "acao": "Investigar cardinalidade, skew de chave, tamanho das partições e estágios críticos."
            })

        for reason in self.detect_possible_missing_pruning():
            findings.append({
                "categoria": "Scan / pruning",
                "severidade": "Alta",
                "titulo": "Possível falta de partition pruning",
                "evidencia": reason,
                "impacto": "Mais dados podem estar sendo lidos do que o necessário.",
                "acao": "Garantir filtro na coluna de partição já nas etapas iniciais."
            })

        repeated_scans = self.detect_repeated_scans()
        if repeated_scans:
            top = list(repeated_scans.items())[:5]
            findings.append({
                "categoria": "Leitura repetida",
                "severidade": "Média",
                "titulo": "Tabelas escaneadas múltiplas vezes",
                "evidencia": f"Principais repetições: {top}",
                "impacto": "Releituras frequentes podem elevar custo e tempo.",
                "acao": "Avaliar materialização intermediária, reutilização de subresultado ou simplificação de CTEs."
            })

        return findings

    # =========================
    # Recomendações priorizadas
    # =========================
    def build_recommendations(self):
        recs = []

        if self.detect_cross_join():
            recs.append(("P0", "Revisar imediatamente joins sem condição ou condições insuficientes."))

        if self._count(r"\bSINGLE\b") >= 2:
            recs.append(("P0", "Reduzir estágios SINGLE: revisar agregações finais globais e sorts finais."))

        if self._count(r"\bExchange\b") >= 5:
            recs.append(("P1", "Diminuir shuffle: filtrar e agregar antes dos joins mais pesados."))

        if self._count(r"\bWindow\b") >= 2:
            recs.append(("P1", "Avaliar se todas as window functions são necessárias na mesma etapa."))

        if self._count(r"\bSort\b") >= 2 or self._count(r"\bTopN\b") >= 2:
            recs.append(("P1", "Reduzir ordenações intermediárias; ordenar apenas no ponto em que isso é estritamente necessário."))

        if self.detect_repeated_scans():
            recs.append(("P1", "Materializar subconjuntos ou bases intermediárias quando a mesma tabela é lida repetidamente."))

        pruning = self.detect_possible_missing_pruning()
        if pruning:
            recs.append(("P0", "Garantir partition pruning nas tabelas grandes, filtrando a partição o mais cedo possível."))

        if self.sql:
            suspicious_ctes = self.map_suspicious_ctes()
            if suspicious_ctes:
                top = suspicious_ctes[:3]
                recs.append(("P1", f"Inspecionar primeiro as CTEs mais suspeitas: {[x['cte'] for x in top]}."))
                recs.append(("P2", "Considerar quebrar CTEs muito pesadas em etapas materializadas (CTAS/Iceberg temporário)."))

        if not recs:
            recs.append(("P2", "Plano sem sinais críticos evidentes; validar com EXPLAIN ANALYZE ou Execution Details do Athena."))

        order = {"P0": 0, "P1": 1, "P2": 2}
        recs = sorted(recs, key=lambda x: order[x[0]])
        return [{"prioridade": p, "recomendacao": r} for p, r in recs]

    # =========================
    # Resumo executivo
    # =========================
    def build_executive_summary(self):
        ops = self.count_operators()
        risk = self.estimate_cost_risk()
        tables = self.detect_tables().most_common(10)
        dist = self.detect_distribution_types()
        fragments = self.detect_fragments()

        bullets = []

        if risk["nivel"] in ("Alto", "Muito Alto"):
            bullets.append(
                f"O plano apresenta risco {risk['nivel'].lower()} de custo/performance, com score heurístico {risk['score']}."
            )
        else:
            bullets.append(
                f"O plano apresenta risco {risk['nivel'].lower()} de custo/performance, com score heurístico {risk['score']}."
            )

        if ops["Exchange"] >= 5:
            bullets.append("Há muitos exchanges, o que sugere redistribuição relevante de dados entre nós.")
        if dist["SINGLE"] >= 2:
            bullets.append("Há indícios de gargalo single-node em parte do plano.")
        if ops["Join"] >= 5:
            bullets.append("A query possui muitos joins, o que aumenta risco de cardinalidade alta e shuffle.")
        if ops["Window"] >= 2:
            bullets.append("Há uso relevante de window functions, potencialmente caras.")
        if self.detect_cross_join():
            bullets.append("Foi detectado cross join, ponto mais crítico do plano.")
        if self.detect_repeated_scans():
            bullets.append("Há tabelas escaneadas repetidamente, sugerindo possível redundância.")

        if not bullets:
            bullets.append("O plano não apresenta sinais textuais muito agressivos, mas ainda vale validar runtime real.")

        return {
            "fragments": fragments,
            "risco": risk,
            "principais_pontos": bullets,
            "top_tabelas_lidas": tables,
            "operadores": ops,
            "distribuicao": dist
        }

    # =========================
    # Markdown bonito
    # =========================
    def to_markdown(self):
        summary = self.build_executive_summary()
        findings = self.build_findings()
        recs = self.build_recommendations()
        suspicious_ctes = self.map_suspicious_ctes()

        lines = []
        lines.append("# Relatório de Interpretação de EXPLAIN")
        lines.append("")
        lines.append("## Resumo executivo")
        lines.append("")
        lines.append(f"- **Fragments detectados:** {summary['fragments']}")
        lines.append(f"- **Risco heurístico:** {summary['risco']['nivel']} (score {summary['risco']['score']})")
        lines.append("")

        for p in summary["principais_pontos"]:
            lines.append(f"- {p}")

        lines.append("")
        lines.append("## Operadores")
        lines.append("")
        for k, v in summary["operadores"].items():
            lines.append(f"- **{k}:** {v}")

        lines.append("")
        lines.append("## Distribuição / Exchange")
        lines.append("")
        for k, v in summary["distribuicao"].items():
            lines.append(f"- **{k}:** {v}")

        lines.append("")
        lines.append("## Tabelas mais lidas")
        lines.append("")
        if summary["top_tabelas_lidas"]:
            for tbl, cnt in summary["top_tabelas_lidas"]:
                lines.append(f"- `{tbl}` → {cnt} menções")
        else:
            lines.append("- Nenhuma tabela identificada textualmente no plano.")

        lines.append("")
        lines.append("## Achados principais")
        lines.append("")
        if findings:
            for f in findings:
                lines.append(f"### {f['titulo']}")
                lines.append(f"- **Categoria:** {f['categoria']}")
                lines.append(f"- **Severidade:** {f['severidade']}")
                lines.append(f"- **Evidência:** {f['evidencia']}")
                lines.append(f"- **Impacto:** {f['impacto']}")
                lines.append(f"- **Ação sugerida:** {f['acao']}")
                lines.append("")
        else:
            lines.append("- Nenhum achado crítico detectado.")
            lines.append("")

        lines.append("## Recomendações priorizadas")
        lines.append("")
        for r in recs:
            lines.append(f"- **{r['prioridade']}** — {r['recomendacao']}")

        lines.append("")
        lines.append("## CTEs suspeitas")
        lines.append("")
        if suspicious_ctes:
            for c in suspicious_ctes:
                lines.append(
                    f"- **{c['cte']}** — score {c['score_heurstico']} — motivos: {', '.join(c['motivos'])}"
                )
        else:
            lines.append("- Nenhuma CTE suspeita identificada heurísticamente ou SQL não fornecido.")

        return "\n".join(lines)

    # =========================
    # JSON final
    # =========================
    def to_dict(self):
        return {
            "resumo_executivo": self.build_executive_summary(),
            "achados": self.build_findings(),
            "recomendacoes": self.build_recommendations(),
            "ctes_suspeitas": self.map_suspicious_ctes(),
            "tabelas_repetidas": self.detect_repeated_scans(),
            "runtime_signals": self.detect_runtime_signals(),
            "partition_signals": self.detect_partition_signals(),
        }

