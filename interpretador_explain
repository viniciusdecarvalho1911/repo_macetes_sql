sql_text = """
WITH contratos_base AS (
    SELECT
        c.contrato,
        c.cnpj,
        c.id_cliente,
        c.escritorio,
        c.tipo_carteira,
        c.esteira,
        c.produto,
        c.segmento,
        c.mesref,
        c.anomesdia,
        c.saldo_aberto,
        c.faixa_atraso,
        c.data_inadimplencia,
        c.data_entrada_carteira,
        c.uf,
        c.cidade
    FROM cobranca.base_contratos c
    WHERE c.mesref BETWEEN 202601 AND 202603
      AND c.tipo_carteira IN ('ATIVO', 'WO')
),

historico_atraso AS (
    SELECT
        h.contrato,
        h.mesref,
        MIN(h.data_atraso) AS primeira_data_atraso_mes,
        MAX(h.dias_atraso) AS max_dias_atraso_mes,
        MAX_BY(h.status_atraso, h.anomesdia) AS status_atraso_fim_mes
    FROM cobranca.hist_atraso h
    WHERE h.mesref BETWEEN 202601 AND 202603
    GROUP BY
        h.contrato,
        h.mesref
),

pagamentos_dia AS (
    SELECT
        p.contrato,
        p.escritorio,
        p.anomesdia,
        p.mesref,
        SUM(p.valor_pago) AS valor_pago_dia,
        COUNT(*) AS qtd_pagamentos_dia
    FROM financeiro.base_pagamentos p
    WHERE p.mesref BETWEEN 202601 AND 202603
      AND p.status_pagamento = 'LIQUIDADO'
    GROUP BY
        p.contrato,
        p.escritorio,
        p.anomesdia,
        p.mesref
),

pagamentos_mes AS (
    SELECT
        p.contrato,
        p.escritorio,
        p.mesref,
        SUM(p.valor_pago_dia) AS valor_pago_mes,
        SUM(p.qtd_pagamentos_dia) AS qtd_pagamentos_mes,
        MAX(p.anomesdia) AS ultima_data_pagamento_mes
    FROM pagamentos_dia p
    GROUP BY
        p.contrato,
        p.escritorio,
        p.mesref
),

boletos_emitidos AS (
    SELECT
        b.contrato,
        b.escritorio,
        b.mesref,
        COUNT(DISTINCT b.id_boleto) AS qtd_boletos_emitidos,
        SUM(b.valor_boleto) AS valor_boletado,
        MAX(b.anomesdia) AS ultima_emissao_boleto
    FROM cobranca.base_boletos b
    WHERE b.mesref BETWEEN 202601 AND 202603
      AND b.status_boleto IN ('EMITIDO', 'PAGO', 'VENCIDO')
    GROUP BY
        b.contrato,
        b.escritorio,
        b.mesref
),

composicao_eventos AS (
    SELECT
        x.contrato,
        x.escritorio,
        x.mesref,
        COUNT(*) AS qtd_eventos_composicao,
        MAX_BY(x.tipo_evento, x.anomesdia) AS ultimo_evento_composicao,
        SUM(CASE WHEN x.tipo_evento = 'BAIXA' THEN 1 ELSE 0 END) AS qtd_baixas,
        SUM(CASE WHEN x.tipo_evento = 'RETROACAO_ATRASO' THEN 1 ELSE 0 END) AS qtd_retroacoes
    FROM cobranca.base_composicao x
    WHERE x.mesref BETWEEN 202601 AND 202603
    GROUP BY
        x.contrato,
        x.escritorio,
        x.mesref
),

acordos_mes AS (
    SELECT
        a.contrato,
        a.escritorio,
        a.mesref,
        MAX_BY(a.id_acordo, a.anomesdia) AS ultimo_acordo,
        MAX_BY(a.status_acordo, a.anomesdia) AS status_acordo_fim_mes,
        MAX_BY(a.valor_acordo, a.anomesdia) AS valor_acordo_fim_mes,
        MAX_BY(a.qtd_parcelas, a.anomesdia) AS qtd_parcelas_fim_mes,
        MAX_BY(a.valor_entrada, a.anomesdia) AS valor_entrada_fim_mes
    FROM cobranca.base_acordos a
    WHERE a.mesref BETWEEN 202601 AND 202603
    GROUP BY
        a.contrato,
        a.escritorio,
        a.mesref
),

juridico_ativo AS (
    SELECT
        j.contrato,
        j.mesref,
        MAX(
            CASE
                WHEN UPPER(j.nome_acao) LIKE '%EXECUCAO%' THEN 1
                ELSE 0
            END
        ) AS fl_execucao_ativa,
        MAX(
            CASE
                WHEN UPPER(j.nome_acao) LIKE '%COBRANCA%' THEN 1
                ELSE 0
            END
        ) AS fl_acao_cobranca,
        MAX_BY(j.nome_acao, j.anomesdia) AS ultima_acao_judicial
    FROM juridico.base_processos j
    WHERE j.mesref BETWEEN 202601 AND 202603
      AND j.status_processo = 'ATIVO'
    GROUP BY
        j.contrato,
        j.mesref
),

dim_escritorio AS (
    SELECT
        e.escritorio,
        e.regional,
        e.cluster,
        e.tipo_operacao
    FROM corporativo.dim_escritorio e
),

dim_cliente AS (
    SELECT
        d.cnpj,
        d.porte_empresa,
        d.segmento_macro,
        d.rating,
        d.uf AS uf_cliente
    FROM clientes.dim_cliente d
),

contrato_enriquecido AS (
    SELECT
        c.contrato,
        c.cnpj,
        c.id_cliente,
        c.escritorio,
        c.tipo_carteira,
        c.esteira,
        c.produto,
        c.segmento,
        c.mesref,
        c.anomesdia,
        c.saldo_aberto,
        c.faixa_atraso,
        c.data_inadimplencia,
        c.data_entrada_carteira,
        c.uf,
        c.cidade,
        de.regional,
        de.cluster,
        de.tipo_operacao,
        dc.porte_empresa,
        dc.segmento_macro,
        dc.rating,
        ha.primeira_data_atraso_mes,
        ha.max_dias_atraso_mes,
        ha.status_atraso_fim_mes,
        pm.valor_pago_mes,
        pm.qtd_pagamentos_mes,
        pm.ultima_data_pagamento_mes,
        be.qtd_boletos_emitidos,
        be.valor_boletado,
        be.ultima_emissao_boleto,
        ce.qtd_eventos_composicao,
        ce.ultimo_evento_composicao,
        ce.qtd_baixas,
        ce.qtd_retroacoes,
        am.ultimo_acordo,
        am.status_acordo_fim_mes,
        am.valor_acordo_fim_mes,
        am.qtd_parcelas_fim_mes,
        am.valor_entrada_fim_mes,
        ja.fl_execucao_ativa,
        ja.fl_acao_cobranca,
        ja.ultima_acao_judicial
    FROM contratos_base c
    LEFT JOIN historico_atraso ha
        ON c.contrato = ha.contrato
       AND c.mesref = ha.mesref
    LEFT JOIN pagamentos_mes pm
        ON c.contrato = pm.contrato
       AND c.escritorio = pm.escritorio
       AND c.mesref = pm.mesref
    LEFT JOIN boletos_emitidos be
        ON c.contrato = be.contrato
       AND c.escritorio = be.escritorio
       AND c.mesref = be.mesref
    LEFT JOIN composicao_eventos ce
        ON c.contrato = ce.contrato
       AND c.escritorio = ce.escritorio
       AND c.mesref = ce.mesref
    LEFT JOIN acordos_mes am
        ON c.contrato = am.contrato
       AND c.escritorio = am.escritorio
       AND c.mesref = am.mesref
    LEFT JOIN juridico_ativo ja
        ON c.contrato = ja.contrato
       AND c.mesref = ja.mesref
    LEFT JOIN dim_escritorio de
        ON c.escritorio = de.escritorio
    LEFT JOIN dim_cliente dc
        ON c.cnpj = dc.cnpj
),

contrato_metrificado AS (
    SELECT
        x.*,
        CASE
            WHEN COALESCE(x.valor_pago_mes, 0) > 0 THEN 1
            ELSE 0
        END AS fl_pagou_mes,
        CASE
            WHEN COALESCE(x.valor_entrada_fim_mes, 0) > 0 THEN 1
            ELSE 0
        END AS fl_entrada_acordo,
        CASE
            WHEN COALESCE(x.valor_pago_mes, 0) >= COALESCE(x.saldo_aberto, 0) THEN 1
            ELSE 0
        END AS fl_liquidacao_total,
        CASE
            WHEN COALESCE(x.valor_pago_mes, 0) > 0
             AND COALESCE(x.valor_pago_mes, 0) < COALESCE(x.saldo_aberto, 0) THEN 1
            ELSE 0
        END AS fl_liquidacao_parcial,
        CASE
            WHEN x.status_acordo_fim_mes IN ('ATIVO', 'FORMALIZADO') THEN 1
            ELSE 0
        END AS fl_acordo_ativo,
        CASE
            WHEN x.status_atraso_fim_mes IN ('QUITADO', 'COLOCADO_EM_DIA', 'RENEGOCIADO') THEN 1
            ELSE 0
        END AS fl_regularizado_status,
        CASE
            WHEN x.fl_execucao_ativa = 1 THEN 'EXECUCAO'
            WHEN x.fl_acao_cobranca = 1 THEN 'COBRANCA_JUDICIAL'
            ELSE 'SEM_JUDICIAL'
        END AS bucket_judicial,
        COALESCE(x.valor_pago_mes, 0) / NULLIF(COALESCE(x.saldo_aberto, 0), 0) AS pct_caixa_sobre_saldo,
        COALESCE(x.valor_acordo_fim_mes, 0) / NULLIF(COALESCE(x.saldo_aberto, 0), 0) AS pct_acordo_sobre_saldo,
        ROW_NUMBER() OVER (
            PARTITION BY x.contrato, x.mesref
            ORDER BY COALESCE(x.valor_pago_mes, 0) DESC, COALESCE(x.qtd_pagamentos_mes, 0) DESC
        ) AS rn_contrato_mes,
        DENSE_RANK() OVER (
            PARTITION BY x.escritorio, x.mesref
            ORDER BY COALESCE(x.valor_pago_mes, 0) DESC
        ) AS rk_caixa_escritorio_mes
    FROM contrato_enriquecido x
),

contrato_metrificado_filtrado AS (
    SELECT
        *
    FROM contrato_metrificado
    WHERE rn_contrato_mes = 1
),

agregado_escritorio_mes AS (
    SELECT
        mesref,
        escritorio,
        regional,
        cluster,
        tipo_carteira,
        esteira,
        bucket_judicial,
        COUNT(*) AS qtd_contratos,
        COUNT(DISTINCT cnpj) AS qtd_cnpjs,
        SUM(saldo_aberto) AS saldo_total,
        SUM(COALESCE(valor_pago_mes, 0)) AS caixa_total,
        SUM(COALESCE(valor_boletado, 0)) AS valor_boletado_total,
        SUM(COALESCE(valor_acordo_fim_mes, 0)) AS valor_acordado_total,
        SUM(CASE WHEN fl_pagou_mes = 1 THEN 1 ELSE 0 END) AS qtd_contratos_com_pagamento,
        SUM(CASE WHEN fl_acordo_ativo = 1 THEN 1 ELSE 0 END) AS qtd_contratos_com_acordo_ativo,
        SUM(CASE WHEN fl_regularizado_status = 1 THEN 1 ELSE 0 END) AS qtd_contratos_regularizados_status,
        SUM(CASE WHEN fl_liquidacao_total = 1 THEN 1 ELSE 0 END) AS qtd_liquidacao_total,
        SUM(CASE WHEN fl_liquidacao_parcial = 1 THEN 1 ELSE 0 END) AS qtd_liquidacao_parcial,
        AVG(COALESCE(pct_caixa_sobre_saldo, 0)) AS avg_pct_caixa_sobre_saldo,
        AVG(COALESCE(pct_acordo_sobre_saldo, 0)) AS avg_pct_acordo_sobre_saldo,
        MAX(rk_caixa_escritorio_mes) AS pior_rank_caixa
    FROM contrato_metrificado_filtrado
    GROUP BY
        mesref,
        escritorio,
        regional,
        cluster,
        tipo_carteira,
        esteira,
        bucket_judicial
),

meta_comissao AS (
    SELECT
        m.mesref,
        m.escritorio,
        m.tipo_carteira,
        m.esteira,
        m.cluster,
        m.meta_caixa,
        m.meta_regularizacao,
        m.pct_comissao
    FROM remuneracao.meta_escritorio m
    WHERE m.mesref BETWEEN 202601 AND 202603
),

resultado_final AS (
    SELECT
        a.mesref,
        a.escritorio,
        a.regional,
        a.cluster,
        a.tipo_carteira,
        a.esteira,
        a.bucket_judicial,
        a.qtd_contratos,
        a.qtd_cnpjs,
        a.saldo_total,
        a.caixa_total,
        a.valor_boletado_total,
        a.valor_acordado_total,
        a.qtd_contratos_com_pagamento,
        a.qtd_contratos_com_acordo_ativo,
        a.qtd_contratos_regularizados_status,
        a.qtd_liquidacao_total,
        a.qtd_liquidacao_parcial,
        a.avg_pct_caixa_sobre_saldo,
        a.avg_pct_acordo_sobre_saldo,
        a.pior_rank_caixa,
        m.meta_caixa,
        m.meta_regularizacao,
        m.pct_comissao,
        a.caixa_total / NULLIF(m.meta_caixa, 0) AS pct_atingimento_meta_caixa,
        a.valor_acordado_total / NULLIF(m.meta_regularizacao, 0) AS pct_atingimento_meta_regularizacao,
        a.caixa_total * COALESCE(m.pct_comissao, 0) AS valor_comissao_estimado
    FROM agregado_escritorio_mes a
    LEFT JOIN meta_comissao m
        ON a.mesref = m.mesref
       AND a.escritorio = m.escritorio
       AND a.tipo_carteira = m.tipo_carteira
       AND a.esteira = m.esteira
       AND COALESCE(a.cluster, 'SEM_CLUSTER') = COALESCE(m.cluster, 'SEM_CLUSTER')
)

SELECT
    *
FROM resultado_final
ORDER BY
    mesref,
    escritorio,
    tipo_carteira,
    esteira,
    bucket_judicial;
"""


