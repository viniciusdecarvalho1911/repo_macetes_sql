## Teste 7 — reconciliação simples de boletos válidos vs consolidado

Esse teste é simples e serve como alerta. Não precisa bater 100% em todos os cenários, mas ajuda a detectar desvio grande.

```sql
WITH fonte AS (
    SELECT
        SUM(vl_pago) AS total_fonte
    FROM workspace_db.vw_base_boletos_pagos
    WHERE dt_ref_yyyymmdd BETWEEN 20260201 AND 20260229
      AND coalesce(flag_cancelado, 0) = 0
),
gold AS (
    SELECT
        SUM(vl_pago) AS total_gold
    FROM workspace_db.tb_gld_sem_pagamento_consolidado
    WHERE p_anomes = 202602
      AND origem_pagamento = 'BOLETO'
)
INSERT INTO workspace_db.tb_auditoria_testes_dados
SELECT
    'exec_202602_001',
    current_timestamp,
    'pipeline_pagamento_consolidado',
    'tb_gld_sem_pagamento_consolidado',
    'teste_reconciliacao_vl_pago_boletos',
    'RECONCILIACAO',
    'WARN',
    'regul_v1',
    CASE
        WHEN coalesce(f.total_fonte,0) = coalesce(g.total_gold,0) THEN 0
        ELSE 1
    END AS qtd_erros,
    NULL,
    0,
    CASE
        WHEN coalesce(f.total_fonte,0) = coalesce(g.total_gold,0) THEN true
        ELSE false
    END AS fl_aprovado,
    concat(
        'Fonte=', cast(coalesce(f.total_fonte,0) as varchar),
        ' | Gold=', cast(coalesce(g.total_gold,0) as varchar)
    ) AS ds_resultado,
    'teste_reconciliacao_vl_pago_boletos.sql',
    NULL
FROM fonte f
CROSS JOIN gold g;
```

