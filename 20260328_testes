## Teste 4 — reconciliação simples

### Objetivo

Comparar total de `vl_pago` entre a fonte consolidada e o gold.

```sql
WITH fonte AS (
    SELECT SUM(vl_pago) AS total_fonte
    FROM workspace_db.vw_base_boletos_pagos
    WHERE dt_ref_yyyymmdd BETWEEN 20260201 AND 20260229
      AND COALESCE(flag_cancelado, 0) = 0
),
gold AS (
    SELECT SUM(vl_pago) AS total_gold
    FROM workspace_db.tb_gld_sem_pagamento_consolidado
    WHERE p_anomes = 202602
)
INSERT INTO workspace_db.tb_auditoria_testes_dados
SELECT
    'exec_202602_001',
    current_timestamp,
    'pipeline_pagamento_consolidado',
    'tb_gld_sem_pagamento_consolidado',
    'teste_reconciliacao_vl_pago',
    'RECONCILIACAO',
    'WARN',
    'regul_v1',
    CASE WHEN abs(coalesce(f.total_fonte,0) - coalesce(g.total_gold,0)) = 0 THEN 0 ELSE 1 END AS qtd_erros,
    NULL,
    0,
    CASE WHEN abs(coalesce(f.total_fonte,0) - coalesce(g.total_gold,0)) = 0 THEN true ELSE false END,
    concat(
        'Fonte=', cast(coalesce(f.total_fonte,0) as varchar),
        ' | Gold=', cast(coalesce(g.total_gold,0) as varchar)
    ),
    'teste_reconciliacao_vl_pago.sql',
    NULL
FROM fonte f
CROSS JOIN gold g;
```

