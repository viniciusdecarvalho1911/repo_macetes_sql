## Teste 1 — unicidade da chave funcional do pagamento

### Objetivo

Garantir que o mesmo pagamento não apareça mais de uma vez após a consolidação.

### Query de erro

```sql
SELECT
    contrato,
    produto,
    dt_pagamento,
    vl_pago,
    COUNT(*) AS qtd
FROM workspace_db.tb_gld_sem_pagamento_consolidado
WHERE p_anomes = 202602
GROUP BY 1,2,3,4
HAVING COUNT(*) > 1;
```

### Query de gravação do resumo

```sql
INSERT INTO workspace_db.tb_auditoria_testes_dados
SELECT
    'exec_202602_001'                                   AS id_execucao,
    current_timestamp                                   AS dt_execucao,
    'pipeline_pagamento_consolidado'                    AS nm_pipeline,
    'tb_gld_sem_pagamento_consolidado'                  AS nm_modelo,
    'teste_unicidade_pagamento_evento'                  AS nm_teste,
    'UNICIDADE'                                         AS tp_teste,
    'FATAL'                                             AS severidade,
    'regul_v1'                                          AS regra_versao,
    COUNT(*)                                            AS qtd_erros,
    NULL                                                AS qtd_linhas_avaliadas,
    0                                                   AS vl_limite_erro,
    CASE WHEN COUNT(*) = 0 THEN true ELSE false END     AS fl_aprovado,
    CASE
        WHEN COUNT(*) = 0 THEN 'Nenhuma duplicidade encontrada'
        ELSE 'Duplicidade encontrada na chave funcional do pagamento'
    END                                                 AS ds_resultado,
    'teste_unicidade_pagamento_evento.sql'              AS ds_query_teste,
    NULL                                                AS ds_observacao
FROM (
    SELECT
        contrato,
        produto,
        dt_pagamento,
        vl_pago
    FROM workspace_db.tb_gld_sem_pagamento_consolidado
    WHERE p_anomes = 202602
    GROUP BY 1,2,3,4
    HAVING COUNT(*) > 1
) t;
```

### Query de detalhe

```sql
INSERT INTO workspace_db.tb_auditoria_testes_detalhe
SELECT
    'exec_202602_001'                                   AS id_execucao,
    current_timestamp                                   AS dt_execucao,
    'pipeline_pagamento_consolidado'                    AS nm_pipeline,
    'tb_gld_sem_pagamento_consolidado'                  AS nm_modelo,
    'teste_unicidade_pagamento_evento'                  AS nm_teste,
    'UNICIDADE'                                         AS tp_teste,
    concat(
        cast(contrato as varchar), '|',
        cast(produto as varchar), '|',
        cast(dt_pagamento as varchar), '|',
        cast(vl_pago as varchar)
    )                                                   AS chave_registro,
    'Duplicidade na chave funcional do pagamento'       AS ds_erro,
    NULL                                                AS payload_erro
FROM (
    SELECT
        contrato,
        produto,
        dt_pagamento,
        vl_pago
    FROM workspace_db.tb_gld_sem_pagamento_consolidado
    WHERE p_anomes = 202602
    GROUP BY 1,2,3,4
    HAVING COUNT(*) > 1
) t;
```

