# 6. Esqueleto de Step Functions

O Step Functions suporta `athena:startQueryExecution.sync` e também há exemplos no guia para executar queries em sequência e em paralelo  . Como o limite de payload entre estados é 256 KiB, não carregue resultado gigante entre estados; passe só parâmetros e deixe o Athena gravar no S3/tabelas de controle .

Abaixo vai um esqueleto lógico, em JSON, enxuto.

```json
{
  "Comment": "Pipeline de modelo + testes + aprovação",
  "StartAt": "DefinirContexto",
  "States": {
    "DefinirContexto": {
      "Type": "Pass",
      "Parameters": {
        "id_execucao.$": "$$.Execution.Id",
        "p_anomes.$": "$.p_anomes",
        "workgroup": "primary",
        "output_location": "s3://SEU-BUCKET/athena-results/",
        "database": "workspace_db"
      },
      "Next": "RodarModeloPrincipal"
    },

    "RodarModeloPrincipal": {
      "Type": "Task",
      "Resource": "arn:aws:states:::athena:startQueryExecution.sync",
      "Arguments": {
        "WorkGroup.$": "$.workgroup",
        "QueryString.$": "$.sql_modelo_principal",
        "ResultConfiguration": {
          "OutputLocation.$": "$.output_location"
        }
      },
      "Next": "RodarTestes"
    },

    "RodarTestes": {
      "Type": "Parallel",
      "Branches": [
        {
          "StartAt": "Teste1",
          "States": {
            "Teste1": {
              "Type": "Task",
              "Resource": "arn:aws:states:::athena:startQueryExecution.sync",
              "Arguments": {
                "WorkGroup.$": "$.workgroup",
                "QueryString.$": "$.sql_teste_1",
                "ResultConfiguration": {
                  "OutputLocation.$": "$.output_location"
                }
              },
              "End": true
            }
          }
        },
        {
          "StartAt": "Teste2",
          "States": {
            "Teste2": {
              "Type": "Task",
              "Resource": "arn:aws:states:::athena:startQueryExecution.sync",
              "Arguments": {
                "WorkGroup.$": "$.workgroup",
                "QueryString.$": "$.sql_teste_2",
                "ResultConfiguration": {
                  "OutputLocation.$": "$.output_location"
                }
              },
              "End": true
            }
          }
        },
        {
          "StartAt": "Teste3",
          "States": {
            "Teste3": {
              "Type": "Task",
              "Resource": "arn:aws:states:::athena:startQueryExecution.sync",
              "Arguments": {
                "WorkGroup.$": "$.workgroup",
                "QueryString.$": "$.sql_teste_3",
                "ResultConfiguration": {
                  "OutputLocation.$": "$.output_location"
                }
              },
              "End": true
            }
          }
        }
      ],
      "Next": "ConsolidarResultadoDosTestes"
    },

    "ConsolidarResultadoDosTestes": {
      "Type": "Task",
      "Resource": "arn:aws:states:::athena:startQueryExecution.sync",
      "Arguments": {
        "WorkGroup.$": "$.workgroup",
        "QueryString.$": "$.sql_consolidacao_testes",
        "ResultConfiguration": {
          "OutputLocation.$": "$.output_location"
        }
      },
      "Next": "AvaliarExecucao"
    },

    "AvaliarExecucao": {
      "Type": "Choice",
      "Choices": [
        {
          "Variable": "$.qtd_fatais",
          "NumericGreaterThan": 0,
          "Next": "FalharExecucao"
        }
      ],
      "Default": "PublicarProximaEtapa"
    },

    "PublicarProximaEtapa": {
      "Type": "Succeed"
    },

    "FalharExecucao": {
      "Type": "Fail",
      "Cause": "Existem testes FATAL reprovados"
    }
  }
}
```

## Observação importante

No mundo real, a parte `AvaliarExecucao` precisa de um jeito de trazer o resultado agregado para o estado. Há 2 caminhos práticos:

1. usar `GetQueryResults` depois da query de consolidação, se o resultado for pequeno
2. mais simples e robusto: gravar a consolidação numa tabela e fazer uma query final pequena que retorne só `qtd_fatais`

Como Step Functions e Athena já expõem `GetQueryResults`, isso é viável no fluxo quando o resultado é pequeno .

