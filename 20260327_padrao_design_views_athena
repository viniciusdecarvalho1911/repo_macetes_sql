# 8. Template oficial de `vw_base`

```sql
CREATE OR REPLACE VIEW workspace_db.vw_base_<entidade> AS
SELECT
    -- física
    <particao_fisica_1> AS p_<particao_fisica_1>,
    <particao_fisica_2> AS p_<particao_fisica_2>,

    -- canônicas
    <expressao_mes> AS mes_ref_yyyymm,
    <expressao_dia> AS dt_ref_yyyymmdd,
    <expressao_data> AS dt_ref_date,
    <expressao_timestamp> AS ts_ref,

    -- chaves
    contrato,
    produto,
    cnpj_raiz,

    -- negócio cru
    escritorio,
    fila,
    cluster_rv,
    atr_ctr,
    vl_saldo,
    vl_ser
FROM workspace_db.<tabela_origem>;
```

---

# 9. Template oficial de `vw_sem`

```sql
CREATE OR REPLACE VIEW workspace_db.vw_sem_<entidade> AS
SELECT
    b.p_<particao_fisica_1>,
    b.p_<particao_fisica_2>,
    b.mes_ref_yyyymm,
    b.dt_ref_yyyymmdd,
    b.dt_ref_date,
    b.ts_ref,
    b.contrato,
    b.produto,
    b.cnpj_raiz,
    b.escritorio,
    b.fila,
    b.cluster_rv,
    b.atr_ctr,
    b.vl_saldo,
    b.vl_ser,

    -- enriquecimento
    coalesce(f.flag_x, 0) as flag_x,
    coalesce(f.flag_y, 0) as flag_y,

    -- regra
    case
        when coalesce(f.flag_x, 0) = 1 then 'CLASSE_X'
        when coalesce(f.flag_y, 0) = 1 then 'CLASSE_Y'
        else 'CLASSE_Z'
    end as tp_status

FROM workspace_db.vw_base_<entidade> b
LEFT JOIN workspace_db.vw_base_<flags> f
  ON b.contrato = f.contrato
 AND b.produto  = f.produto;
```

